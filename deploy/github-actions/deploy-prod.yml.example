# PRIVATE PROJECT: copy this file to .github/workflows/deploy-prod.yml
# after replacing runner labels, branch names, Compose project names, and secret names.
name: Deploy Prod

on:
  workflow_dispatch:

concurrency:
  group: obp-server-deploy
  cancel-in-progress: false

jobs:
  deploy:
    runs-on: [self-hosted, linux, obp-deploy]
    environment: prod
    env:
      COMPOSE_PROJECT_NAME: obp-prod
      DEPLOY_ENV_FILE_NAME: obp-prod.env
    steps:
      - uses: actions/checkout@v4
        with:
          ref: main

      - name: Write prod env file on the server
        env:
          DEPLOY_ENV_FILE: ${{ secrets.PROD_ENV_FILE }}
        run: |
          set -eu
          DEPLOY_ENV_FILE_PATH="${RUNNER_TEMP}/${DEPLOY_ENV_FILE_NAME}"

          if [ -z "${DEPLOY_ENV_FILE:-}" ]; then
            echo "::error::PROD_ENV_FILE is empty; set it in the prod environment."
            exit 1
          fi

          umask 077
          printf '%s\n' "$DEPLOY_ENV_FILE" > "$DEPLOY_ENV_FILE_PATH"

      - name: Deploy prod from checked-out source
        run: |
          set -eu
          DEPLOY_ENV_FILE_PATH="${RUNNER_TEMP}/${DEPLOY_ENV_FILE_NAME}"
          docker compose -p "$COMPOSE_PROJECT_NAME" --profile migrate --env-file "$DEPLOY_ENV_FILE_PATH" -f deploy/compose.yml -f deploy/compose.prod.example.yml -f deploy/compose.proxy.yml build
          docker compose -p "$COMPOSE_PROJECT_NAME" --env-file "$DEPLOY_ENV_FILE_PATH" -f deploy/compose.yml -f deploy/compose.prod.example.yml -f deploy/compose.proxy.yml up -d postgres redis
          docker compose -p "$COMPOSE_PROJECT_NAME" --env-file "$DEPLOY_ENV_FILE_PATH" -f deploy/compose.yml -f deploy/compose.prod.example.yml -f deploy/compose.proxy.yml stop api web
          docker compose -p "$COMPOSE_PROJECT_NAME" --profile migrate --env-file "$DEPLOY_ENV_FILE_PATH" -f deploy/compose.yml -f deploy/compose.prod.example.yml -f deploy/compose.proxy.yml run --rm migrator
          docker compose -p "$COMPOSE_PROJECT_NAME" --env-file "$DEPLOY_ENV_FILE_PATH" -f deploy/compose.yml -f deploy/compose.prod.example.yml -f deploy/compose.proxy.yml up -d --remove-orphans
          docker compose -p "$COMPOSE_PROJECT_NAME" --env-file "$DEPLOY_ENV_FILE_PATH" -f deploy/compose.yml -f deploy/compose.prod.example.yml -f deploy/compose.proxy.yml ps
