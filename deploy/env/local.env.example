# Local deployment-stack test template.
# Use this when you want to run the production-like Docker stack on your laptop.

COMPOSE_PROJECT_NAME=obp-local-deploy
APP_NAME=Open Business Platform
APP_ENV=Staging
ASPNETCORE_ENVIRONMENT=Staging

PUBLIC_SCHEME=http
PUBLIC_HOST=localhost
HTTP_PORT=8080
HTTPS_PORT=8443
API_PORT=5080
POSTGRES_PORT=55440
REDIS_PORT=6385

API_UPSTREAM=api:5080
WEB_UPSTREAM=web:80

AUTH_COOKIE_NAME=obp.local.deploy.auth
AUTH_COOKIE_REQUIRE_SECURE=false
BRAND_LOGO_TEXT=OBP
DEFAULT_COMPANY_NAME=Your Company
DEFAULT_COMPANY_LOGO_URL=/logo.svg

POSTGRES_DB=open_business_platform_local_deploy
POSTGRES_USER=obp_local_deploy
POSTGRES_PASSWORD=local-deploy-postgres-password

BOOTSTRAP_ADMIN_EMAIL=admin.local@example.com
BOOTSTRAP_ADMIN_PASSWORD=local-deploy-bootstrap-password

API_IMAGE=open-business-platform-api:local-deploy
WEB_IMAGE=open-business-platform-web:local-deploy
