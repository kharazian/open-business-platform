# Production deployment template.
# PRIVATE PROJECT: copy to deploy/env/prod.env or keep real values on the server.
# Never commit real passwords or bootstrap credentials.

COMPOSE_PROJECT_NAME=obp-prod
APP_NAME=Open Business Platform
APP_ENV=Production
ASPNETCORE_ENVIRONMENT=Production

PUBLIC_SCHEME=https
PUBLIC_HOST=app.example.com
HTTP_PORT=80
HTTPS_PORT=443

AUTH_COOKIE_NAME=obp.prod.auth
AUTH_COOKIE_REQUIRE_SECURE=true
BRAND_LOGO_TEXT=OBP
DEFAULT_COMPANY_NAME=Your Company
DEFAULT_COMPANY_LOGO_URL=/logo.svg

POSTGRES_DB=open_business_platform_prod
POSTGRES_USER=obp_prod
POSTGRES_PASSWORD=replace-with-prod-postgres-password

BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-prod-bootstrap-password

# Password recovery email.
PASSWORD_RESET_URL=https://app.example.com/reset-password
EMAIL_FROM_ADDRESS=no-reply@example.com
SMTP_HOST=replace-with-prod-smtp-host
SMTP_USERNAME=replace-with-prod-smtp-username
SMTP_PASSWORD=replace-with-prod-smtp-password

API_IMAGE=open-business-platform-api:prod
API_MIGRATOR_IMAGE=open-business-platform-api-migrator:prod
WEB_IMAGE=open-business-platform-web:prod
