# Staging deployment template.
# PRIVATE PROJECT: copy to deploy/env/stage.env or keep real values on the server.
# Never commit real passwords or bootstrap credentials.

COMPOSE_PROJECT_NAME=obp-stage
APP_NAME=Open Business Platform
APP_ENV=Staging
ASPNETCORE_ENVIRONMENT=Staging

PUBLIC_SCHEME=http
PUBLIC_HOST=10.10.50.60
HTTP_PORT=8080
HTTPS_PORT=8443

AUTH_COOKIE_NAME=obp.stage.auth
# PRIVATE PROJECT: keep false only for temporary HTTP/IP testing.
# Set to true when staging uses HTTPS.
AUTH_COOKIE_REQUIRE_SECURE=false
BRAND_LOGO_TEXT=OBP
DEFAULT_COMPANY_NAME=Your Company
DEFAULT_COMPANY_LOGO_URL=/logo.svg

POSTGRES_DB=open_business_platform_stage
POSTGRES_USER=obp_stage
POSTGRES_PASSWORD=replace-with-stage-postgres-password

BOOTSTRAP_ADMIN_EMAIL=admin.stage@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-stage-bootstrap-password

API_IMAGE=open-business-platform-api:stage
API_MIGRATOR_IMAGE=open-business-platform-api-migrator:stage
WEB_IMAGE=open-business-platform-web:stage
