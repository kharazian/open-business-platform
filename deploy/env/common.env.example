# Shared deployment environment template.
# PRIVATE PROJECT: copy values into stage.env/prod.env or your server's env store.
# Do not commit real passwords, private domains, or production bootstrap values.

APP_NAME=Open Business Platform
BRAND_LOGO_TEXT=OBP
DEFAULT_COMPANY_NAME=Your Company
DEFAULT_COMPANY_LOGO_URL=/logo.svg

# Caddy/proxy ports.
HTTP_PORT=80
HTTPS_PORT=443

# Image names are local-build defaults for now.
# Later, private projects can point these at registry-published images.
API_IMAGE=open-business-platform-api:local
API_MIGRATOR_IMAGE=open-business-platform-api-migrator:local
WEB_IMAGE=open-business-platform-web:local
