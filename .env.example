# Open Business Platform local environment

# App identity
COMPOSE_PROJECT_NAME=open-business-platform
APP_NAME=Open Business Platform
APP_ENV=Development

# Branding defaults
BRAND_LOGO_TEXT=OBP
DEFAULT_COMPANY_NAME=Your Company
DEFAULT_COMPANY_LOGO_URL=/logo.svg

# Bootstrap admin
# Server-only. Do not expose these as VITE_ variables.
BOOTSTRAP_ADMIN_EMAIL=admin@company.test
BOOTSTRAP_ADMIN_PASSWORD=change-me-before-use
AUTH_COOKIE_NAME=obp.auth
AUTH_COOKIE_REQUIRE_SECURE=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=open_business_platform
POSTGRES_USER=obp
POSTGRES_PASSWORD=obp_dev_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend / ASP.NET Core
API_PORT=5080
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5080

# Frontend / Vite
# Only VITE_ variables are available in browser code.
VITE_APP_NAME=Open Business Platform
VITE_APP_HOST=127.0.0.1
VITE_APP_PORT=5174
VITE_API_BASE_URL=http://localhost:5080
VITE_COMPANY_NAME=Your Company
VITE_COMPANY_LOGO_URL=/logo.svg

# Optional direct ASP.NET overrides.
# Use these when you need values that cannot be represented safely above.
# ConnectionStrings__Postgres=Host=localhost;Port=55432;Database=open_business_platform;Username=obp;Password=obp_dev_password
# ConnectionStrings__Redis=localhost:6379
# BootstrapAdmin__Email=admin@company.test
# BootstrapAdmin__Password=change-me-before-use
# Authentication__CookieName=obp.auth
# Branding__LogoText=OBP
# Branding__CompanyName=Your Company
# Branding__LogoUrl=/logo.svg
# Cors__AllowedOrigins__0=http://localhost:5174
# Cors__AllowedOrigins__1=http://127.0.0.1:5174
